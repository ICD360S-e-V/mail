[Desktop Entry]
Type=Application
Name=ICD360S Mail Client
GenericName=Mail Client
Comment=Modern email client with mTLS, PGP, and threat detection
Exec=launcher.sh %U
Icon=de.icd360s.mailclient
Terminal=false
