# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Signing credentials (NEVER commit)
android/key.properties
android/upload-keystore.jks

# Certificates and private keys
certificates/*.pem
certificates/*.key
certificates/*.p12
certificates/*.p8
certificates/*.srl

# SSH keys
vps_*.de
vps_*.pub

# Backup directories
backup_*/

# Stale/temp files
version_temp.json

# Claude settings (may contain sensitive commands)
.claude/settings.local.json

# Windows installer redistributables (downloaded fresh in CI from Microsoft with SHA-256 pin)
windows/redist/*.exe
windows/redist/*.msi
