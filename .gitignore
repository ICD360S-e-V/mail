/android/app/release

# Signing credentials (NEVER commit)
android/key.properties
android/upload-keystore.jks

# Certificates and private keys (broad — never commit cryptographic material)
certificates/*.pem
certificates/*.key
certificates/*.p12
certificates/*.p8
certificates/*.srl
certificates/*.csr
certificates/*.crt
certificates/*.cer
certificates/*.pfx
certificates/*.jks
*.pfx
*.p12
*.pem
*.key
*.csr
*.crt

# But DO allow public-ish stuff that's intentionally shipped
!linux/icd360s-appimage-pubkey.asc
!android/app/src/main/res/xml/network_security_config.xml

# SSH keys
vps_*.de
vps_*.pub

# Backup directories
backup_*/

# Stale/temp files
version_temp.json

# Claude settings (may contain sensitive commands)
.claude/settings.local.json

# Windows installer redistributables (downloaded fresh in CI from Microsoft with SHA-256 pin)
windows/redist/*.exe
windows/redist/*.msi

# Environment & secrets files (NEVER commit)
.env
.env.*
.envrc
secrets.json
*.secret
*.secrets

# Mobile provisioning profiles (iOS code signing)
*.mobileprovision
*.provisionprofile

# Firebase config (often contain API keys)
**/google-services.json
**/GoogleService-Info.plist

# Editor backup files
*~
*.bak
*.orig

# Local notes / scratchpads (use private docs instead)
notes.txt
todo.txt
idee.txt
TODO.txt

# GPG temporary files
.gnupg/
*.gpg
*.asc.tmp

version_signing_priv.pem
version_signing_pub.pem

# SSH keypair for mail.icd360s.de (windows-client@icd360s.de identity).
# Private key MUST NEVER be committed; public counterpart kept out too
# to avoid leaking server access topology.
mail.icd360s.de
mail.icd360s.de.pub

# Project credential/topology doc — references SSH port, user, key paths.
# Kept local-only; never push to GitHub.
CLAUDE.md

# WireGuard keypair for mail.icd360s.de's wg0 tunnel to ops.icd360s.de.
# Same exclusion reason as SSH keys: secrets, never commit.
mail.icd360s.de.wg0.priv.key
mail.icd360s.de.wg0.pub.key
mail.icd360s.de.restic-repo-password.txt

